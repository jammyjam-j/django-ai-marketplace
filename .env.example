SECRET_KEY=django-insecure-CHANGE_ME
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

DATABASE_URL=postgres://user:password@db:5432/marketplace

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_password

LANGCHAIN_API_KEY=YOUR_LANGCHAIN_API_KEY
LANGCHAIN_MODEL=gpt-4o-mini
LANGCHAIN_MAX_TOKENS=512
LANGCHAIN_TIMEOUT=30

STATIC_URL=/static/
MEDIA_URL=/media/
MEDIA_ROOT=/var/www/marketplace/media/

CACHES_REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

SENTRY_DSN=
SENTRY_ENVIRONMENT=development

TIME_ZONE=UTC
LANGUAGE_CODE=en-us

RECOMMENDER_TOP_K=5
RECOMMENDER_SIMILARITY_THRESHOLD=0.7

# Docker specific
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_EMAIL=admin@example.com

LOG_LEVEL=DEBUG

DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=marketplace
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=db
DATABASE_PORT=5432

REDIS_URL=redis://redis:6379/0
CACHE_BACKEND=redis.cache.RedisCache
CACHE_LOCATION=${REDIS_URL}
CACHE_TIMEOUT=300

ALLOWED_ORIGINS=http://localhost:8000 http://127.0.0.1:8000

CSRF_TRUSTED_ORIGINS=${ALLOWED_ORIGINS}

DEFAULT_AUTO_FIELD=django.db.models.BigAutoField

# Optional services
WEBSOCKET_ENABLED=False
WEBHOOK_SECRET=webhook_secret_key

S3_BUCKET_NAME=marketplace-bucket
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=${S3_BUCKET_NAME}
AWS_S3_CUSTOM_DOMAIN=${S3_BUCKET_NAME}.s3.amazonaws.com

# API rate limits
API_RATE_LIMIT=1000
API_RATE_PERIOD=60

# Logging configuration
LOGGING_LEVEL=DEBUG
LOG_FILE_PATH=/var/log/marketplace/app.log

# Health check
HEALTH_CHECK_URL=http://localhost:8000/health/

# Feature flags
ENABLE_RECOMMENDATIONS=True
ENABLE_STOCK_ALERTS=False

# Internationalization
USE_I18N=True
USE_L10N=True
USE_TZ=True

# Miscellaneous
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=SAMEORIGIN
HSTS_SECONDS=0
HSTS_INCLUDE_SUBDOMAINS=False
HSTS_PRELOAD=False

# API keys for third party services
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Analytics
GA_TRACKING_ID=
PLAUSIBLE_DOMAIN=example.com

# Deployment
DEPLOYMENT_ENVIRONMENT=development
DEPLOYMENT_VERSION=1.0.0

# Testing
TEST_RUNNER=django.test.runner.DiscoverRunner
TEST_DISCOVER_ROOT=tests

# Database migrations
MIGRATION_MODULES={'auth': 'custom_auth.migrations'}

# Email templates directory
EMAIL_TEMPLATES_DIR=/var/www/marketplace/email_templates

# Cache settings for recommendations
RECOMMENDER_CACHE_TIMEOUT=86400

# Logging rotation
LOG_ROTATION_BACKUP_COUNT=7
LOG_ROTATION_MAX_BYTES=10485760

# Security keys
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 settings
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTHORIZATION_ENDPOINT=https://provider.com/oauth/authorize
OAUTH2_TOKEN_ENDPOINT=https://provider.com/oauth/token

# CDN configuration
CDN_URL=http://cdn.example.com/
STATICFILES_STORAGE=whitenoise.storage.CompressedManifestStaticFilesStorage

# Webhook endpoints
WEBHOOK_ENDPOINTS={"order_created":"/webhooks/order/", "payment_successful":"/webhooks/payment/"}

# Cron jobs
CRON_SCHEDULE="0 * * * *"

# Feature toggles
FEATURE_TOGGLES={"beta_feature_x":false, "experimental_ui":true}